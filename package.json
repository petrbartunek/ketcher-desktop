{
  "name": "ketcher-desktop",
  "version": "0.1.0",
  "description": "Desktop chemical structure editor — Electron shell around EPAM Ketcher",
  "main": "electron/main.js",
  "author": "",
  "license": "Apache-2.0",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build:renderer": "vite build",
    "start": "npm run build:renderer && electron .",
    "package": "npm run build:renderer && electron-builder",
    "register-scheme": "node tools/register-scheme.js",
    "unregister-scheme": "node tools/register-scheme.js --revert",
    "package:mac":    "npm run build:renderer && electron-builder --mac --arm64 --x64",
    "package:win":    "npm run build:renderer && electron-builder --win --x64",
    "package:linux":  "npm run build:renderer && electron-builder --linux --x64",
    "package:all":    "npm run build:renderer && electron-builder --mac --win --linux --arm64 --x64"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "ketcher-core": "^2.27.0",
    "ketcher-react": "^2.27.0",
    "ketcher-standalone": "^2.27.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.11",
    "vite-plugin-node-polyfills": "^0.22.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.example.ketcher-desktop",
    "productName": "Ketcher Desktop",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.education",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "afterPack": "build/after-pack.js",
    "win": {
      "target": ["nsis"],
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Science",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "protocols": [
      {
        "name": "Ketcher Structure",
        "schemes": ["ketcher"]
      }
    ]
  }
}
